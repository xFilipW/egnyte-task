# Copy this file to .env and fill in the values.
# The application reads these via process.env at startup.

# Port the microservice listens on (default: 4000)
PORT=4000

# Comma-separated list of allowed CORS origins.
# Set to the frontend URL in production; leave empty to allow all origins locally.
# Example: CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=
